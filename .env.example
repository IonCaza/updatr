# ── Environment ───────────────────────────────────────────────────────────
# Set to "production" for optimised, non-reloading builds.
# Defaults to "development" (live-reload, debug output).
NODE_ENV=development

# ── Ports ─────────────────────────────────────────────────────────────────
# Each service listens on the configured port both inside and outside Docker.
# One port, no translation — internal connections, external access,
# and remote worker URLs all use the same value.
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DB=updatr
POSTGRES_USER=updatr
POSTGRES_PASSWORD=changeme

# ── Application ───────────────────────────────────────────────────────────
# These connection strings use Docker-internal hostnames.
# The ports here are auto-substituted from *_PORT above in docker-compose.
DATABASE_URL=postgresql+asyncpg://updatr:changeme@postgres:5432/updatr
REDIS_URL=redis://redis:6379/0

# URL the browser uses to reach the backend API.
# Set this to the externally-reachable address of the backend (hostname or IP).
# If accessing the UI from the same machine, http://localhost:<BACKEND_PORT> works.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Allowed CORS origins (comma-separated).
# Must include every URL you use to access the frontend in a browser.
CORS_ORIGINS=http://localhost:3000

# ── Security ──────────────────────────────────────────────────────────────
SECRET_KEY=changeme-generate-a-random-64-char-string
ENCRYPTION_KEY=changeme-generate-a-random-32-byte-hex-key

# ── Remote workers (optional) ─────────────────────────────────────────────
# Set REDIS_PASSWORD to secure Redis when exposing it over VPN.
# When set, update REDIS_URL to: redis://:yourpassword@redis:6379/0
# REDIS_PASSWORD=

# Bind addresses: set to 0.0.0.0 to allow remote worker connections over VPN.
# Default: 127.0.0.1 (local only)
# REDIS_BIND=0.0.0.0
# POSTGRES_BIND=0.0.0.0
